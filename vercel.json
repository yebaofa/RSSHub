{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "framework": "hono",
    "outputDirectory": "src",
    "functions": {
        "src/server.mjs": {
            "includeFiles": "node_modules/.pnpm/patchright-core@*/node_modules/patchright-core/browsers.json",
            "maxDuration": 300
        }
    },
    "rewrites": [
        {
            "source": "/favicon.ico",
            "destination": "/favicon.png"
        }
    ],
    "github": {
        "silent": true
    }
}
